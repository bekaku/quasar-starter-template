# backend only:
# DOTENV_BOOL=true
# client (with default QCLI_ prefix) & backend:
# QCLI_DOTENV_BOOL=true

QCLI_APP_API_TIME_OUT= 300000 #// 60000 = 1 minute, 0 = no timeout
QCLI_APP_API_CLIENT= 'default'
QCLI_APP_VERSION= '1.0.3'
QCLI_APP_CODE_VERSION= 1
QCLI_APP_WEB_URL='https://app.yourdomain.com'
QCLI_APP_API_DOMAIN='yourdomain.com'
QCLI_APP_DEFAULT_LOCALE = en
QCLI_APP_PREFIX_KEY = _myappkey_

QCLI_APP_DEV_MODE= 'false'
QCLI_APP_BASE_API= 'https://api.yourapp.com'
QCLI_APP_BASE_CDN_API= 'https://cdn.yourapp.com'
QCLI_APP_PUBLIC_PATH= '/'
# QCLI_APP_PUBLIC_PATH= '/quasar-starter'